#!/usr/bin/env bash
# Usage: ./scripts/build-at <commit> [outdir]
# Generates resume outputs for any git commit without disturbing HEAD.
set -euo pipefail

COMMIT=${1:?commit required}
OUT="${2:-./out}"
WT=$(mktemp -d)

cleanup() { git worktree remove --force "$WT" || true; }
trap cleanup EXIT

mkdir -p "$OUT"
OUT=$(realpath "$OUT")

git worktree add --detach "$WT" "$COMMIT"

TYPST_ARGS=()
[[ -n "${PHONE:-}" ]] && TYPST_ARGS+=(--input "phone=$PHONE")

typst compile "$WT/resume.typ" "$OUT/resume.pdf" "${TYPST_ARGS[@]}"
typst compile "$WT/resume.typ" "$OUT/resume.png" "${TYPST_ARGS[@]}" --pages 1
typst compile "$WT/resume.typ" "$OUT/resume.svg" "${TYPST_ARGS[@]}" --pages 1

echo "Output: $OUT"
